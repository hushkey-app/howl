{
  "name": "@howl/_backend",
  "version": "0.0.1",
  "tasks": {
    "dev": "deno run -A --watch=. --watch-exclude=dist/,node_modules/,generated/ dev.ts",
    "build": "deno run -A dev.ts build",
    "start": "deno run -A dist/compiled-entry.js",
    "compile": "deno compile -A --output dist/bin/backend-only dist/compiled-entry.js"
  },
  "exports": "./server/main.ts",
  "imports": {
    "@hushkey/howl": "jsr:@hushkey/howl@^0.15.1",
    "zod": "npm:zod@4.3.6",
    "@std/path": "jsr:@std/path@^1.0.0"
  },
  "compilerOptions": {
    "jsx": "react-jsx",
    "jsxImportSource": "vue",
    "lib": ["dom", "dom.iterable", "deno.ns", "deno.unstable"]
  }
}
