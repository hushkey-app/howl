{
  "name": "@howl/docs",
  "version": "0.0.1",
  "tasks": {
    "dev": "deno run -A --env-file='../../.env' --watch --watch-exclude=dist/,node_modules/ dev.ts",
    "build": "deno run -A dev.ts build",
    "start": "deno run -A  dist/compiled-entry.js",
    "compile": "deno compile --output ./dist/bin/www --include dist --include static -A dist/compiled-entry.js"
  },
  "exports": "./server/main.ts",
  "imports": {
    "@hushkey/howl": "jsr:@hushkey/howl@^0.12.0",
    "@hushkey/howl/dev": "jsr:@hushkey/howl@^0.12.0/dev",
    "@hushkey/howl/api": "jsr:@hushkey/howl@^0.12.0/api",
    "@hushkey/howl-react": "jsr:@hushkey/howl-react@^0.12.0",
    "@std/path": "jsr:@std/path@^1.0.0",
    "react": "npm:react@^18.3.1",
    "react/jsx-runtime": "npm:react@^18.3.1/jsx-runtime",
    "react-dom": "npm:react-dom@^18.3.1",
    "react-dom/server": "npm:react-dom@^18.3.1/server",
    "react-dom/client": "npm:react-dom@^18.3.1/client",
    "tailwindcss": "npm:tailwindcss@4.1.18",
    "zod": "npm:zod@4.3.6",
    "daisyui": "npm:daisyui@5.5.18"
  },
  "compilerOptions": {
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "jsxImportSourceTypes": "npm:@types/react@^18.3.0",
    "lib": ["dom", "dom.iterable", "deno.ns", "deno.unstable"]
  }
}
