{
  "name": "@howl/_db",
  "version": "0.0.1",
  "tasks": {
    "dev": "deno run -A --watch=dev.ts,howl.config.ts,server/,client/,static/ dev.ts",
    "build": "deno run -A dev.ts build",
    "start": "deno run -A dist/compiled-entry.js",
    "compile": "deno compile -A --include dist/static --output dist/bin/db dist/compiled-entry.js"
  },
  "exports": "./server/main.ts",
  "imports": {
    "@hushkey/howl": "jsr:@hushkey/howl@^0.14.8",
    "@hushkey/howl-vue": "jsr:@hushkey/howl-vue@^0.14.8",
    "@hushkey/service-core": "jsr:@hushkey/service-core@^0.14.8",
    "@hushkey/mongo-service": "jsr:@hushkey/mongo-service@^0.14.8",
    "@hushkey/pg-service": "jsr:@hushkey/pg-service@^0.14.8",
    "@hushkey/sqlite-service": "jsr:@hushkey/sqlite-service@^0.14.8",
    "@hushkey/studio": "jsr:@hushkey/studio@^0.14.8",
    "zod": "npm:zod@4.3.6",
    "mongodb": "npm:mongodb@^6.0.0",
    "pg": "npm:pg@^8.13.0",
    "@electric-sql/pglite": "npm:@electric-sql/pglite@^0.2.0",
    "@std/path": "jsr:@std/path@^1.0.0",
    "@unhead/vue": "npm:@unhead/vue@^2.0.0",
    "vue": "npm:vue@^3.5.13",
    "vue/server-renderer": "npm:vue@^3.5.13/server-renderer",
    "@vue/runtime-dom": "npm:@vue/runtime-dom@^3.5.13",
    "tailwindcss": "npm:tailwindcss@4.1.18",
    "daisyui": "npm:daisyui@5.5.18"
  },
  "compilerOptions": {
    "jsx": "react-jsx",
    "jsxImportSource": "vue",
    "lib": ["dom", "dom.iterable", "deno.ns", "deno.unstable"]
  }
}
