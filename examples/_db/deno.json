{
  "name": "@howl/_db",
  "version": "0.0.1",
  "tasks": {
    "dev": "deno run -A --watch=. --watch-exclude=dist/,node_modules/,generated/,data/ dev.ts",
    "build": "deno run -A dev.ts build",
    "start": "deno run -A dist/compiled-entry.js"
  },
  "exports": "./server/main.ts",
  "imports": {
    "@hushkey/howl": "jsr:@hushkey/howl@^0.12.0",
    "@hushkey/service-core": "jsr:@hushkey/service-core@^0.1.0",
    "@hushkey/mongo-service": "jsr:@hushkey/mongo-service@^0.1.0",
    "@hushkey/pg-service": "jsr:@hushkey/pg-service@^0.1.0",
    "@hushkey/sqlite-service": "jsr:@hushkey/sqlite-service@^0.1.0",
    "zod": "npm:zod@4.3.6",
    "mongodb": "npm:mongodb@^6.0.0",
    "pg": "npm:pg@^8.13.0",
    "@electric-sql/pglite": "npm:@electric-sql/pglite@^0.2.0",
    "@std/path": "jsr:@std/path@^1.0.0"
  },
  "compilerOptions": {
    "lib": ["dom", "deno.ns", "deno.unstable"]
  }
}
