{
  "nodeModulesDir": "auto",
  "workspace": [
    "./packages/howl",
    "./packages/howl-vue",
    "./packages/howl-react",
    "./packages/howl-init",
    "./examples/www",
    "./examples/software-www",
    "./examples/hybrid-spa",
    "./examples/vuety",
    "./examples/reacty"
  ],
  "tasks": {
    "dev:vuety": "deno run -A --watch examples/vuety/dev.ts",
    "build:vuety": "deno run -A examples/vuety/dev.ts build",
    "start:vuety": "deno run -A examples/vuety/dist/compiled-entry.js",
    "dev:reacty": "deno run -A --watch examples/reacty/dev.ts",
    "build:reacty": "deno run -A examples/reacty/dev.ts build",
    "start:reacty": "deno run -A examples/reacty/dist/compiled-entry.js",
    "lint": "deno lint",
    "fmt": "deno fmt",
    "check": "deno check packages/howl/core/mod.ts packages/howl/dev/mod.ts",
    "test": "deno test -A --no-check packages/howl/tests/ packages/howl-init/tests/ packages/howl-vue/tests/ packages/howl-react/tests/",
    "test:vue": "deno test -A --no-check packages/howl-vue/tests/",
    "test:react": "deno test -A --no-check packages/howl-react/tests/",
    "test:integration": "deno test -A --no-check packages/howl/tests/integration/",
    "test:api": "deno test -A --no-check packages/howl/tests/api/",
    "test:unit": "deno test -A --no-check packages/howl/tests/unit/",
    "test:init": "deno test -A --no-check packages/howl-init/tests/",
    "doc:lint": "cd packages/howl && deno doc --lint core/mod.ts core/client.ts dev/mod.ts plugins/mod.ts api/mod.ts api/errors.ts api/cache/mod.ts core/middlewares/mod.ts core/middlewares/cors.ts core/middlewares/csrf.ts core/middlewares/csp.ts core/middlewares/trailing_slashes.ts core/middlewares/static_files.ts"
  },
  "lint": {
    "rules": {
      "tags": [
        "recommended"
      ],
      "exclude": [
        "no-explicit-any"
      ]
    },
    "exclude": [
      "**/node_modules",
      "**/_howl",
      "**/.git"
    ]
  },
  "fmt": {
    "useTabs": false,
    "lineWidth": 100,
    "indentWidth": 2,
    "semiColons": true,
    "singleQuote": false,
    "exclude": [
      "**/node_modules",
      "**/_howl"
    ]
  },
  "imports": {},
  "allowScripts": ["npm:vue-demi@0.14.10"]
}
